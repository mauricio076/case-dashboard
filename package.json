{
  "name": "expediente",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env dev",
    "deploy:dev": "WORKER_ENV=dev bash scripts/deploy.sh",
    "deploy:full": "bash scripts/deploy.sh",
    "deploy:prod": "WORKER_ENV=production bash scripts/deploy.sh",
    "build:check": "wrangler deploy --env dev --dry-run --outdir=dist",
    "db:create": "wrangler d1 create expediente-dev",
    "db:init": "wrangler d1 execute expediente --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute expediente-dev --remote --file=schema.sql",
    "types": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.98.0"
  }
}
