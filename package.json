{
  "name": "expediente",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:full": "bash scripts/deploy.sh",
    "build:check": "wrangler deploy --dry-run --outdir=dist",
    "db:create": "wrangler d1 create expediente",
    "db:init": "wrangler d1 execute expediente --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute expediente --remote --file=schema.sql",
    "types": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.7"
  }
}
